[include]
	path = ~/.config/git/colors
[advice]
	detachedHead = false
	statusHints = false
	suggestDetachingHead = false
[alias]
	adog = log --all --graph --pretty=custom-oneline
	df = difftool
	mr = mergetool
	rl = log --walk-reflogs --pretty=custom-reflog
	shlf = !git -C $SHLF_DIR
[blame]
	coloring = highlightRecent
	date = relative
[core]
	editor = nvim
	excludesFile = ~/.config/git/ignore
	hooksPath = ~/.config/git/hooks/
[diff]
	interHunkContext = 3
	noprefix = true
	tool = nvimdiff
[difftool]
	prompt = false
[init]
	defaultBranch = main
[merge]
	tool = nvimdiff1
[mergetool]
	keepBackup = false
[trailer]
	ifExists = addIfDifferent
